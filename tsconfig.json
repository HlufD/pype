{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "./",
    "outDir": "./dist",
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": [
    "src",
    "tests"
  ]
}